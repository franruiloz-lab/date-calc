---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | CountingDate"
  description="The page you're looking for doesn't exist. Browse our free date and time calculators."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center py-20">
    <!-- Clock icon -->
    <div class="w-20 h-20 bg-brand-50 border border-brand-100 rounded-3xl flex items-center justify-center mb-6">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
        <line x1="12" y1="2" x2="12" y2="4"/>
        <line x1="12" y1="20" x2="12" y2="22"/>
        <line x1="2" y1="12" x2="4" y2="12"/>
        <line x1="20" y1="12" x2="22" y2="12"/>
      </svg>
    </div>

    <div class="text-8xl font-extrabold text-brand-100 mb-2 leading-none">404</div>
    <h1 class="text-2xl font-extrabold text-navy-900 mb-3">Page not found</h1>
    <p class="text-slate-500 max-w-md mb-8">
      Looks like this page got lost in time. Try one of our calculators below.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-10">
      <a href="/" class="btn-primary">← Back to Home</a>
      <a href="/date-calculator/" class="inline-flex items-center gap-2 bg-white border border-slate-200 hover:border-brand-300 text-navy-900 text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
        Date Calculator
      </a>
      <a href="/days-from/28-days-from-today/" class="inline-flex items-center gap-2 bg-white border border-slate-200 hover:border-brand-300 text-navy-900 text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
        28 Days From Today
      </a>
      <a href="/countdown-timer/how-long-until-3-00-pm/" class="inline-flex items-center gap-2 bg-white border border-slate-200 hover:border-brand-300 text-navy-900 text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
        Countdown Timer
      </a>
    </div>

    <!-- Popular calculators -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-2xl">
      {[
        { label: 'Age Calculator', href: '/age-calculator/', icon: '🎂' },
        { label: 'Days Between Dates', href: '/days-between-dates/', icon: '📆' },
        { label: 'Business Days', href: '/business-days-calculator/', icon: '💼' },
        { label: 'Days Left in Year', href: '/days-left-in-year/', icon: '🗓️' },
      ].map(({ label, href, icon }) => (
        <a href={href} class="flex flex-col items-center gap-2 bg-white border border-slate-200 hover:border-brand-300 hover:shadow-sm rounded-xl p-4 transition-all group">
          <span class="text-2xl">{icon}</span>
          <span class="text-xs font-semibold text-navy-900 group-hover:text-brand-600 text-center transition-colors">{label}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
