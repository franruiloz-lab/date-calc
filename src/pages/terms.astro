---
import BaseLayout from '../layouts/BaseLayout.astro';

const lastUpdated = 'April 6, 2026';
const siteUrl = 'https://countingdate.com';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Terms of Use — CountingDate",
    "description": "Terms of use for CountingDate.com — conditions governing your use of our free date and time calculators.",
    "url": `${siteUrl}/terms/`,
    "dateModified": "2026-04-06",
    "isPartOf": { "@type": "WebSite", "name": "CountingDate", "url": siteUrl },
    "inLanguage": "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Terms of Use", "item": `${siteUrl}/terms/` },
    ],
  },
];
---

<BaseLayout
  title="Terms of Use | CountingDate"
  description="Terms of use for CountingDate.com — conditions governing your use of our free date and time calculators. Please read before using the site."
  schema={schema}
>
  <div class="bg-white border-b border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-brand-600 transition-colors">Home</a>
        <span>›</span>
        <span class="text-navy-900 font-medium">Terms of Use</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-navy-900 mb-2">Terms of Use</h1>
      <p class="text-slate-500 text-sm">Last updated: {lastUpdated}</p>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 rounded-xl px-5 py-4 mb-8 text-sm text-yellow-800">
      <strong>Important:</strong> CountingDate provides calculators for informational and planning purposes only. Results should not be relied upon for legal, financial, medical, or other professional decisions without independent verification.
    </div>

    <div class="space-y-8 text-slate-700 leading-relaxed">

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">1. Acceptance of terms</h2>
        <p>
          By accessing or using CountingDate (<strong>countingdate.com</strong>), you agree to be bound by these Terms of Use. If you do not agree, please do not use the site.
          These terms apply to all visitors and users of the website.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">2. Description of service</h2>
        <p>
          CountingDate provides free, browser-based date and time calculators including, but not limited to: date calculators, days-from-today calculators, countdown timers, age calculators, and business day calculators.
          All tools are provided free of charge, without registration, and without any guarantee of availability.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">3. Accuracy of results</h2>
        <p>
          While we strive for accuracy, CountingDate makes no warranties — express or implied — about the correctness or completeness of any calculation result.
          Results are based on your device's local clock and timezone, which may be incorrect. Factors such as:
        </p>
        <ul class="list-disc pl-6 space-y-1.5 mt-3 text-sm">
          <li>Daylight Saving Time transitions</li>
          <li>Timezone differences between parties</li>
          <li>Public holidays (not included in business day calculations)</li>
          <li>Leap year edge cases</li>
          <li>Your device's system clock being set incorrectly</li>
        </ul>
        <p class="mt-3">
          ...may affect results. <strong>Always verify critical dates independently</strong> before making legal, financial, or contractual decisions.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">4. Not professional advice</h2>
        <p>
          Nothing on CountingDate constitutes legal, financial, medical, tax, or any other professional advice. The calculators are general-purpose tools.
          For any decision with material consequences, consult a qualified professional.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">5. Intellectual property</h2>
        <p>
          All content on CountingDate — including but not limited to text, code, design, and calculator logic — is the property of Francisco Ruiz Lozano unless otherwise stated.
          You may use the calculators freely for personal and commercial purposes. You may not copy, reproduce, or redistribute the site's design or codebase without explicit written permission.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">6. Limitation of liability</h2>
        <p>
          To the fullest extent permitted by applicable law, CountingDate and its operators shall not be liable for any direct, indirect, incidental, special, or consequential damages arising from:
        </p>
        <ul class="list-disc pl-6 space-y-1.5 mt-3 text-sm">
          <li>Use of or inability to use the site or its calculators</li>
          <li>Errors or inaccuracies in calculator results</li>
          <li>Any decisions made based on calculator output</li>
          <li>Temporary or permanent unavailability of the service</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">7. External links</h2>
        <p>
          CountingDate may contain links to third-party websites. These are provided for convenience only. We do not endorse or take responsibility for the content, privacy practices, or accuracy of any linked site.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">8. Changes to the service</h2>
        <p>
          We reserve the right to modify, suspend, or discontinue any part of the site at any time without notice. We may also update these Terms of Use at any time. The "last updated" date will reflect the most recent revision. Continued use of the site constitutes acceptance of the updated terms.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">9. Governing law</h2>
        <p>
          These terms are governed by the laws of Spain. Any disputes arising from the use of CountingDate shall be subject to the exclusive jurisdiction of the courts of Spain.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-navy-900 mb-3">10. Contact</h2>
        <p>
          Questions about these Terms of Use? Contact us at:<br/>
          <a href="mailto:franruizlozano31@gmail.com" class="text-brand-600 hover:underline font-medium">franruizlozano31@gmail.com</a>
        </p>
      </section>

    </div>

    <div class="mt-10 pt-6 border-t border-slate-200 flex gap-4 text-sm">
      <a href="/" class="text-brand-600 hover:underline">← Back to Home</a>
      <a href="/privacy/" class="text-brand-600 hover:underline">Privacy Policy →</a>
    </div>
  </div>
</BaseLayout>
